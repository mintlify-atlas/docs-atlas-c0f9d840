  "keyFeatures": [
    "PDF and TXT paper ingestion with automated chunking and background indexing",
    "Retrieval-augmented question answering with inline source citations",
    "Research intelligence reports: consensus, gaps, contradictions, and trends",
    "AI-assisted paper section drafting grounded in the uploaded library",
    "Session-scoped paper libraries with persistent chat history",
    "Export completed papers as DOCX or PDF",
    "Streaming SSE-based chat responses with confidence scoring",
    "Docker Compose deployment with Qdrant vector store"
  ],
